{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@agentforge/api": [
        "./packages/api/src/*"
      ],
      "@agentforge/web": [
        "./packages/web/src/*"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "packages/**/*",
    "src/**/*",
    ".next/types/**/*.ts"
  ],
"exclude": [
    "node_modules",
    ".paperclip-reference",
    "packages/api"
  ]
}
