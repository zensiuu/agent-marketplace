{
  "name": "agentforge",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:api": "cd packages/api && pnpm dev",
    "build": "next build && cd packages/api && pnpm build",
    "build:web": "cd packages/web && pnpm build",
    "start": "next start",
    "start:api": "cd packages/api && pnpm start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "vercel",
    "preview:api": "vercel --prod packages/api"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "vercel": "^37.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
