{
  "name": "agentforge",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm run dev --prefix packages/api",
    "build": "next build && npm run build --prefix packages/api",
    "build:web": "npm run build --prefix packages/web",
    "start": "next start",
    "start:api": "npm run start --prefix packages/api",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "preview": "vercel"
  },
  "dependencies": {
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "vercel": "^37.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
