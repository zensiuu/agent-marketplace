# ===========================================
# AgentForge Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3003
VERCEL_OIDC_TOKEN=
# ===========================================
# AUTH0 - Authentication & Token Vault
# ===========================================
# Get these from: https://manage.auth0.com/dashboard
#
# IMPORTANT: For Auth0 SDK v4 with Next.js App Router:
# - The SDK auto-generates callback URLs: {AUTH0_BASE_URL}/api/auth/callback
# - So AUTH0_BASE_URL=http://localhost:3003 → callback is http://localhost:3003/api/auth/callback
# - Add this exact callback URL in your Auth0 dashboard under:
#   Application → Settings → Allowed Callback URLs
#
AUTH0_SECRET='use-openssl-rand-hex-32'  # Generate: openssl rand -hex 32
AUTH0_BASE_URL='http://localhost:3003'   # MUST match Auth0 dashboard callback URL base
AUTH0_DOMAIN='agentforge-hub.eu.auth0.com'
AUTH0_ISSUER_BASE_URL='https://agentforge-hub.eu.auth0.com'
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# For AI Agent Token Vault (Machine-to-Machine)
AUTH0_A2A_DOMAIN='agentforge-hub.auth0.com'
AUTH0_A2A_CLIENT_ID=
AUTH0_A2A_CLIENT_SECRET=
# ===========================================
# DATABASE & SERVICES
# ===========================================
# Supabase PostgreSQL
DATABASE_URL='postgresql://postgres.[ref]:[pass]@aws-0-...pooler.supabase.com:6543/postgres'
# Paperclip (Agent Orchestration)
PAPERCLIP_API_URL='https://api.paperclip.ai'       # Or localhost for dev
PAPERCLIP_API_KEY='...'                            # From Paperclip dashboard
PAPERCLIP_COMPANY_ID='...'                         # Your company ID in Paperclip
# Stripe (Payments - Optional for MVP)
STRIPE_SECRET_KEY='sk_live-...'                    # Later
STRIPE_WEBHOOK_SECRET='whsec_...'                 # Later
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY='pk_live_...'  # Later
# ===========================================
# CORS & SECURITY
# ===========================================
ALLOWED_ORIGINS='http://localhost:3000,http://localhost:3003'