# AgentForge Environment Variables
# Copy this file to .env.local and fill in your values

# API URL for the frontend to call the backend
NEXT_PUBLIC_API_URL=http://localhost:3000

# Paperclip Configuration
PAPERCLIP_API_URL=https://api.paperclip.ai
PAPERCLIP_API_KEY=your-paperclip-api-key-here

# Auth0 Authentication (for hackathon - Token Vault for AI agents)
AUTH0_SECRET='use-openssl-rand-hex-32'
AUTH0_BASE_URL='http://localhost:3000'
AUTH0_ISSUER_BASE_URL='https://YOUR_TENANT.auth0.com'
AUTH0_CLIENT_ID='YOUR_AUTH0_CLIENT_ID'
AUTH0_CLIENT_SECRET='YOUR_AUTH0_CLIENT_SECRET'

# Auth0 AI Agent Token Vault (for hackathon demo)
AUTH0_A2A_CLIENT_ID='YOUR_AI_AGENT_CLIENT_ID'
AUTH0_A2A_CLIENT_SECRET='YOUR_AI_AGENT_CLIENT_SECRET'

# Database (for future PostgreSQL setup)
DATABASE_URL=postgresql://user:password@localhost:5432/agentforge

# Stripe (for payments - optional for MVP)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
